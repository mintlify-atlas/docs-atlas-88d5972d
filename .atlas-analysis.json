  "keyFeatures": [
    "Reactive properties with automatic re-rendering on state changes",
    "Expressive HTML templates using tagged template literals",
    "Scoped CSS styles with Shadow DOM encapsulation",
    "Lightweight component lifecycle with efficient diffing",
    "Rich set of built-in directives (repeat, classMap, styleMap, ref, etc.)",
    "TypeScript decorators for clean component authoring",
    "Reactive controllers for composable, reusable logic",
    "Server-side rendering support via @lit-labs/ssr",
    "Context protocol for passing data through element trees",
    "Async task management with @lit/task"
  ],
  "publicApiSurface": [
    "LitElement (base class for web components)",
    "html (tagged template literal for HTML templates)",
    "css (tagged template literal for scoped styles)",
    "svg (tagged template literal for SVG templates)",
    "render() (renders a template to a container)",
    "ReactiveElement (low-level reactive base class)",
    "@customElement() decorator",
    "@property() decorator",
    "@state() decorator",
    "@query() / @queryAll() / @queryAsync() decorators",
    "@eventOptions() decorator",
